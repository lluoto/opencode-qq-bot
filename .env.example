# QQ Bot
QQ_APP_ID=102935014
QQ_APP_SECRET=
QQ_SANDBOX=false

# 可选：当前单 Bot 的默认模型
# OPENCODE_DEFAULT_MODEL=openai/gpt-5.4

# 多 Bot 模式（与上面的 QQ_APP_ID / QQ_APP_SECRET 二选一）
# QQ_BOTS_JSON=[{"id":"bot-a","appId":"101","clientSecret":"...","sandbox":false,"defaultModel":"openai/gpt-5.4"},{"id":"bot-b","appId":"102","clientSecret":"...","sandbox":false,"opencodeBaseUrl":"http://127.0.0.1:4097","defaultModel":"anthropic/claude-sonnet-4-5"}]

# OpenCode (留空=自动启动内嵌 serve, 填写=连接外部 serve)
# OPENCODE_BASE_URL=http://localhost:4096

# 安全 (逗号分隔的 user_openid, 留空不限制)
ALLOWED_USERS=

# 消息
MAX_REPLY_LENGTH=3000
