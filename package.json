  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.20",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.9.0"
  }
