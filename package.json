{
  "name": "opencode-qq-bot",
  "version": "0.1.1",
  "type": "module",
  "description": "QQ Bot for OpenCode AI - chat with AI coding assistant via QQ",
  "bin": {
    "openqq": "./bin/openqq.js"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
